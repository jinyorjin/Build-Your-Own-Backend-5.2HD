              "pm.test(\"Response is an object\", function () {\r",
              "    pm.expect(artwork).to.be.an(\"object\");\r",
              "});\r",
              "\r",
              "pm.test(\"Created artwork has required properties\", function () {\r",
              "    pm.expect(artwork).to.have.property(\"id\");\r",
              "    pm.expect(artwork).to.have.property(\"title\");\r",
              "    pm.expect(artwork).to.have.property(\"artistName\");\r",
              "    pm.expect(artwork).to.have.property(\"description\");\r",
              "    pm.expect(artwork).to.have.property(\"imageUrl\");\r",
              "    pm.expect(artwork).to.have.property(\"status\");\r",
              "    pm.expect(artwork).to.have.property(\"locationId\");\r",
              "});\r",
              "\r",
              "const requestBody = JSON.parse(pm.request.body.raw);\r",
              "\r",
              "pm.test(\"Created artwork values match request body\", function () {\r",
              "    pm.expect(artwork.title).to.eql(requestBody.title);\r",
              "    pm.expect(artwork.artistName).to.eql(requestBody.artistName);\r",
              "    pm.expect(artwork.description).to.eql(requestBody.description);\r",
              "    pm.expect(artwork.imageUrl).to.eql(requestBody.imageUrl);\r",
              "    pm.expect(artwork.status).to.eql(requestBody.status);\r",
              "    pm.expect(Number(artwork.locationId)).to.eql(Number(requestBody.locationId));\r",
              "});\r",
              "\r",
              "pm.environment.set(\"artworkId\", artwork.id);\r",
              "pm.environment.set(\"deletedArtworkId\", artwork.id);"
