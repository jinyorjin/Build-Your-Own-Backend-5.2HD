    {
      "name": "Create Location",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201 Created\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "const location = pm.response.json();\r",
              "\r",
              "pm.test(\"Response is an object\", function () {\r",
              "    pm.expect(location).to.be.an(\"object\");\r",
              "});\r",
              "\r",
              "pm.test(\"Created location has required properties\", function () {\r",
              "    pm.expect(location).to.have.property(\"id\");\r",
              "    pm.expect(location).to.have.property(\"name\");\r",
              "    pm.expect(location).to.have.property(\"latitude\");\r",
              "    pm.expect(location).to.have.property(\"longitude\");\r",
              "});\r",
              "\r",
              "\r",
              "const requestBody = JSON.parse(pm.request.body.raw);\r",
              "\r",
              "pm.test(\"Created location values match request body\", function () {\r",
              "    pm.expect(location.name).to.eql(requestBody.name);\r",
              "    pm.expect(Number(location.latitude)).to.eql(Number(requestBody.latitude));\r",
              "    pm.expect(Number(location.longitude)).to.eql(Number(requestBody.longitude));\r",
              "});\r",
              "\r",
              "// 변수 저장\r",
              "pm.environment.set(\"locationId\", location.id);\r",
              "pm.environment.set(\"deletedLocationId\", location.id);\r",
              "pm.environment.set(\"locationId\", location.id);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
